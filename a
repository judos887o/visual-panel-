local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
table.insert(Shared.Connections[key], UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end))

local lines = {}
local function getLine()
    for _, l in ipairs(lines) do
        if not l.Visible then return l end
    end
    local line = Instance.new("Frame")
    line.Name = "Tracer"
    line.AnchorPoint = Vector2.new(0.5, 0.5)
    line.BackgroundColor3 = COL.ESP
    line.BorderSizePixel = 0
    line.Parent = overlay
    line.Visible = false
    table.insert(lines, line)
    return line
end

local padBillboards = {}

local function ensurePadBillboard(pad, labelText, color)
    if padBillboards[pad] then
        padBillboards[pad].Enabled = true
        return
    end
    local headPart = pad:FindFirstChild("Head") or pad:FindFirstChildWhichIsA("BasePart")
    if not headPart then return end
    local bb = Instance.new("BillboardGui")
    bb.Name = "SchmecktPadESP"
    bb.Adornee = headPart
    bb.Size = UDim2.new(0, 200, 0, 30)
    bb.StudsOffset = Vector3.new(0, 4, 0)
    bb.AlwaysOnTop = true
    bb.Parent = pad
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.Text = labelText
    txt.TextColor3 = color
    txt.Font = Enum.Font.GothamBlack
    txt.TextSize = 14
    txt.TextStrokeTransparency = 0.3
    txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    txt.Parent = bb
    padBillboards[pad] = bb
end

local function removePadBillboard(pad)
    if padBillboards[pad] then
        padBillboards[pad]:Destroy()
        padBillboards[pad] = nil
    end
end

local function removeAllPadBillboards()
    for pad, bb in pairs(padBillboards) do
        pcall(function() bb:Destroy() end)
    end
    padBillboards = {}
end

local function removeAllHighlights()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr.Character then
            local hl = plr.Character:FindFirstChild("SchmecktHighlight")
            if hl then hl:Destroy() end
        end
    end
end

local function cleanAllESP()
    removeAllHighlights()
    removeAllPadBillboards()
    for _, line in ipairs(lines) do
        line.Visible = false
    end
end

local function getPadsFolder()
    local m = Workspace:FindFirstChild("MAP")
    if m and m:FindFirstChild("Pads") then return m.Pads end
    return nil
end

local function updateESP()
    for _, line in ipairs(lines) do line.Visible = false end

    if not Shared.VisualPanel then
        gui.Enabled = false
        overlay.Enabled = false
        cleanAllESP()
        return
    end

    gui.Enabled = true
    overlay.Enabled = true

    if Shared.EspPlayers then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= lp and plr.Character then
                local char = plr.Character
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if root and hum and hum.Health > 0 then
                    if not char:FindFirstChild("SchmecktHighlight") then
                        local hl = Instance.new("Highlight")
                        hl.Name = "SchmecktHighlight"
                        hl.FillColor = COL.ESP
                        hl.OutlineColor = COL.ESP_Outline
                        hl.FillTransparency = 0.5
                        hl.OutlineTransparency = 0.2
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        hl.Parent = char
                    end
                end
            end
        end
    else
        removeAllHighlights()
    end

    if Shared.TracersEnabled then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= lp and plr.Character then
                local root = plr.Character:FindFirstChild("HumanoidRootPart")
                local hum = plr.Character:FindFirstChild("Humanoid")
                if root and hum and hum.Health > 0 then
                    local vec, onScreen = Camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local line = getLine()
                        local startPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        local endPos = Vector2.new(vec.X, vec.Y)
                        local distance = (endPos - startPos).Magnitude
                        local center = (startPos + endPos) / 2
                        local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)
                        line.Size = UDim2.new(0, distance, 0, 1.5)
                        line.Position = UDim2.new(0, center.X, 0, center.Y)
                        line.Rotation = math.deg(angle)
                        line.Visible = true
                    end
                end
            end
        end
    end

    local padsFolder = getPadsFolder()
    if padsFolder then
        if Shared.EspWeapons then
            for _, pad in ipairs(padsFolder:GetChildren()) do
                if weaponNames[pad.Name] then
                    ensurePadBillboard(pad, pad.Name, Color3.fromRGB(255, 50, 50))
                end
            end
        else
            for _, pad in ipairs(padsFolder:GetChildren()) do
                if weaponNames[pad.Name] then
                    removePadBillboard(pad)
                end
            end
        end

        if Shared.EspFood then
            for _, pad in ipairs(padsFolder:GetChildren()) do
                if foodNames[pad.Name] then
                    ensurePadBillboard(pad, pad.Name, Color3.fromRGB(50, 255, 100))
                end
            end
        else
            for _, pad in ipairs(padsFolder:GetChildren()) do
                if foodNames[pad.Name] then
                    removePadBillboard(pad)
                end
            end
        end
    end
end

